{
  "permissions": {
    "allow": [
      "Glob",
      "Grep",
      "LS",
      "Read",
      "Read(*)",
      "TodoWrite",
      "WebFetch",
      "WebSearch",
      "Bash(git add *)",
      "Bash(nix flake check *)",
      "Bash(nix flake lock *)",
      "Bash(nix flake update *)",
      "Bash(nix eval *)",
      "Bash(nix build *)",
      "Bash(nix fmt *)"
    ],
    "deny": [],
    "ask": [],
    "defaultMode": "plan",
    "additionalDirectories": []
  },
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true,
    "elements-of-style@superpowers-marketplace": true
  },
  "outputStyle": "XP Programmer"
}
